; Engine configuration file.
; It is best edited using the editor UI and not directly,
; but the resource file format is well-documented and not prone to changes,
; so manually editing is possible.
;
; FORMAT:
;   [section] ; section goes in []
;   param=value ; parameter assignments go here

config_version=5

[application]

config/name="testdungeon"
config/description="A sprite-based roguelike – Godot 4.5 port"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Constants="*res://scripts/autoloads/Constants.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=960
window/size/resizable=false
window/stretch/mode="disabled"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
